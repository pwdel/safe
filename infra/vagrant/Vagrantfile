Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/noble64"
  config.vm.hostname = "safe-vm"
  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider "virtualbox" do |vb|
    vb.name = "safe-vm"
    vb.memory = 4096
    vb.cpus = 2
  end

  config.vm.network "forwarded_port", guest: 22, host: 2222, id: "ssh", auto_correct: true

  # Treat the checked-in safe repo as control-plane source, not as the writable coding workspace.
  config.vm.synced_folder "../../", "/opt/safe-control", type: "virtualbox", mount_options: ["ro"]

  config.vm.provision "ansible" do |ansible|
    ansible.playbook = "../ansible/playbooks/site.yml"
    ansible.inventory_path = "../ansible/inventory/vagrant.ini"
    ansible.limit = "safevm"
    ansible.verbose = "v"
    ansible.extra_vars = {
      app_root: "/opt/safe-control",
      workspace_root: "/srv/workspaces",
      fork_root: "/srv/workspaces/forks",
      admin_user: "operator",
      safe_user: "reviewer"
    }
  end
end
