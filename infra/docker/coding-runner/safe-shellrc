export SAFE_GUARD_ACTIVE=1

safe_guard_notice() {
  cat <<'EOF'
safe runner guardrails active
- wrapped commands: rm chmod chown dd mkfs fdisk sfdisk parted mount umount
- bypass only when intentional: export SAFE_ALLOW_RISKY=1
- global git hooks active: ~/.git-hooks (pre-commit and pre-push)
- secret scanning on commit/push: trufflehog (bypass: SAFE_SKIP_SECRET_SCAN=1)
EOF
}

if [[ -n "${PS1:-}" ]]; then
  safe_guard_notice
fi
