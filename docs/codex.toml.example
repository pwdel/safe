# Example Codex config for this repo's infra-focused workflow.
#
# This example intentionally excludes repo-local hook scripts. Runtime task
# behavior should be sourced from the external task-spec repo and applied
# manually in the runner environment.

web_search = "disabled"
tools.view_image = false
model = "gpt-5"
approval_policy = "on-request"
sandbox_mode = "workspace-write"

[features]
shell_tool = true
multi_agent = false
apps = false
image_generation = false
codex_hooks = false

[shell_environment_policy]
inherit = "core"

[ghost_snapshot]
ignore_large_untracked_dirs = true
